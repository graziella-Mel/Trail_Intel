{
  "name": "trail-intel",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "predev": "npm run trails:import",
    "dev": "vinext dev",
    "prebuild": "npm run trails:import",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs && node --experimental-strip-types --test tests/recommendations.test.ts tests/live-hike.test.ts tests/integration-flow.test.ts tests/trail-import.test.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "trails:import": "node --experimental-strip-types scripts/import-trails.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "mapbox-gl": "^3.26.0",
    "next": "16.2.6",
    "openai": "^6.47.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-loading-skeleton": "3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
